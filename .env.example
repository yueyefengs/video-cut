# 必须
DASHSCOPE_API_KEY=sk-your-key-here

# 字幕样式
SUBTITLE_FONT_NAME=PingFang SC
SUBTITLE_FONT_SIZE=42
SUBTITLE_BOLD=1
SUBTITLE_COLOR=&H00FFFFFF
SUBTITLE_OUTLINE_COLOR=&H00000000
SUBTITLE_OUTLINE=4
SUBTITLE_MARGIN_V=80
SUBTITLE_ALIGNMENT=2       # 1=左下 2=居中下 3=右下

SUBTITLE_CHARS_PER_LINE=8  # 每条字幕最大字符数
